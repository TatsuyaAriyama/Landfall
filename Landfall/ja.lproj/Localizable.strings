/* サインイン */
"Sign in to enter the harbor." = "サインインして、入港しましょう。";
"Your record syncs across your devices." = "記録は、複数の端末で同期されます。";
"Continue with Google" = "Googleで続ける";
"Account" = "アカウント";
"Sign out" = "サインアウト";
"Delete account" = "アカウントを削除";
"Delete your account?" = "アカウントを削除する?";
