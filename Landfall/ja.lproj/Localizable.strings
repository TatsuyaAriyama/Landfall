"Delete this record?" = "この記録を削除する?";

/* 日の詳細 */
"%@ · %lld items this day" = "この日 %@・%lld項目";
"No records left for this day." = "この日の記録は、もうない。";
"No item" = "項目なし";

/* 軌跡 */
"Trace of %@" = "%@の軌跡";
"Days logged" = "記録した日";
"Waiting for this month's first mark." = "今月の最初のひと刻みを待っている。";

/* 波形 */
"Return" = "帰還";
"%lld-day gap" = "%lld日の空白";
"%lldd" = "%lld日";

/* Wrapped 画面 */
"Your first Wrapped arrives at month's end." = "最初のWrappedは、月末に生まれる。";
"At month's end, the whole month becomes one page." = "月の終わりに、その月のすべてが一枚になる。";

/* Wrapped カード1(事実) */
"You, %@" = "%@のあなた";
"studied" = "学んだ";
"rested" = "休んだ";
"And you never once quit." = "そして、一度もやめなかった。";

/* Wrapped カード2(空白の物語) */
"Your longest gap" = "いちばん長い空白";
"%@–%@, you fell silent." = "%@〜%@、あなたは沈黙した。";
"And yet on %@, you came back." = "それでも %@、戻ってきた。";
"%lld returns this month." = "この月、帰還は%lld回。";
"No gap this month." = "この月、空白はなかった。";

/* Wrapped カード3(タイプ診断) */
"Your comeback type" = "あなたの再開力タイプ";
"Comeback %lld" = "再開力 %lld";
"%lld returns" = "帰還 %lld回";

/* タイプ名 */
"Phoenix" = "不死鳥型";
"Stone Bridge" = "石橋型";
"Wave Rider" = "波乗り型";
"Comet" = "彗星型";
"Morning Calm" = "朝凪型";

/* タイプ 決め台詞(1行目) */
"Sink deep. Always return." = "深く沈み、必ず戻る。";
"Quietly, surely, you build." = "静かに、確実に、積む。";
"You have your own tide." = "あなたには、あなたの潮がある。";
"When you burn, you burn all at once." = "燃えるときは、一気に。";
"No noise, no rush, no break." = "騒がず、焦らず、途切れず。";

/* タイプ 添え書き(2行目) */
"The length of the gap is nothing to you." = "空白の長さは、あなたには関係がない。";
"No flourish needed. What you stack remains." = "派手さはいらない。積んだものが残る。";
"Some days ebb so others can flow." = "引く日があるから、満ちる日がある。";
"The stillness is only your next approach." = "静けさは、次の助走にすぎない。";
"That calm is your greatest strength." = "その静けさが、いちばん強い。";
