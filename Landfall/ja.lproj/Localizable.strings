"%lld min" = "%lld分";
"0 min" = "0分";
"A note (optional)" = "ひとこと(任意)";
"Log this" = "この分を刻む";

/* 項目エディタ */
"Add item" = "項目を追加";
"Edit item" = "項目を編集";
"Name (e.g. Reading, Coding)" = "名前(例: 読書、開発)";
