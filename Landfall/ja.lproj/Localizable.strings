/* Wrapped カード1(事実) */
"You, %@" = "%@のあなた";
"studied" = "学んだ";
"rested" = "休んだ";
/* カード1の締め(月の形で出し分け。日数ベース判定) */
"You were out at sea all month." = "ひと月まるごと、海に出ていた。";
"You sailed almost every day." = "ほとんど毎日、航海に出た。";
"You set sail, even once. That's enough." = "一度でも、海に出た。それでいい。";
"Away for a long stretch — and back again." = "長く離れても、戻ってきた。";
