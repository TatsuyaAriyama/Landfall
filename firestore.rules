rules_version = '2';

// Landfall Firestore セキュリティルール。
//
// 方針:
//  - users/{uid}/** … 本人だけが読み書きできる私的バックアップ。
//  - rooms/{code}   … 招待コード(=ドキュメントID)を知る者が入れる友人向けの港。
//                      コードそのものが合鍵。中身は港名とメンバー一覧のみ。
//  - members/…      … 同じ港のメンバー同士だけが互いのカード・記録を読める。
//                      書き込めるのは本人だけ。
//
// 不変条件(重要):
//  - 誰も他人のドキュメントを書けない。
//  - 港の更新は「自分だけを出し入れする」に限定する。港名・作成者・他メンバーは
//    改変できない(在港者による乗っ取り・追い出しを防ぐ)。
//  - 一覧(list)は自分が属する港/共有だけ。コード総当たりでの列挙を防ぐ。
//  - 文字列・配列は型と長さを検証し、肥大化した書き込みを弾く。
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- 私的バックアップ: 本人のみ ----
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ---- 港(ルーム) ----
    match /rooms/{roomId} {

      // get: コードを知っていれば単票は読める(参加のための存在確認・サインイン必須)。
      // list: 自分が属する港だけ。コード総当たりでの列挙・メンバーUID収集を防ぐ。
      allow get: if request.auth != null;
      allow list: if request.auth != null
        && request.auth.uid in resource.data.memberIds;

      // 作成: 自分だけをメンバーに入れて作る。ownerUid は作成者本人(以後不変・権限は無い)。
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['name', 'memberIds', 'createdAt', 'ownerUid'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 80
        && request.resource.data.memberIds == [request.auth.uid]
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.createdAt is timestamp;

      // 更新: 「自分だけを加える」または「自分だけを外す」に限定。
      // 港名・作成日時・他メンバーは一切改変できず、余計なフィールドも足せない
      // (共有ドキュメントへの肥大データ注入を防ぐ)。
      allow update: if request.auth != null
        && request.resource.data.keys().hasOnly(['name', 'memberIds', 'createdAt', 'ownerUid'])
        && request.resource.data.name == resource.data.name
        && request.resource.data.createdAt == resource.data.createdAt
        && ( !('ownerUid' in resource.data)
          || request.resource.data.ownerUid == resource.data.ownerUid )
        && request.resource.data.memberIds is list
        && ( addsOnlySelf() || removesOnlySelf() );

      // 港ドキュメント自体の削除は不可。
      allow delete: if false;

      // 自分だけを1人加えた(他メンバーは全員そのまま)。人数上限で多重防御。
      function addsOnlySelf() {
        return !(request.auth.uid in resource.data.memberIds)
          && request.auth.uid in request.resource.data.memberIds
          && request.resource.data.memberIds.hasAll(resource.data.memberIds)
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
          && request.resource.data.memberIds.size() <= 4;   // プライベートの港は4人まで
      }

      // 自分だけを1人外した(他メンバーは誰も追加・削除していない)。
      function removesOnlySelf() {
        return request.auth.uid in resource.data.memberIds
          && !(request.auth.uid in request.resource.data.memberIds)
          && resource.data.memberIds.hasAll(request.resource.data.memberIds)
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1;
      }

      function isMember() {
        return request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds;
      }

      // ---- メンバーのプレイヤーカード ----
      match /members/{memberId} {
        // 読めるのは同じ港のメンバーだけ。
        allow read: if isMember();

        // 書けるのは、その港のメンバー本人だけ。フィールドは既知のものに限り、型と長さを検証する
        // (未参加の港へのドキュメント設置や、余計なフィールド・肥大データの注入を防ぐ)。
        // boat* は船の見た目(部位id)。任意フィールド=hasOnly のサブセット規則により、
        // これらを書かない旧クライアント(iOS)の従来5フィールド書き込みもそのまま通る。
        allow create, update: if request.auth != null
          && request.auth.uid == memberId
          && isMember()
          && request.resource.data.keys().hasOnly(['displayName', 'styleToken', 'symbolToken', 'resolve', 'joinedAt', 'boatSail', 'boatJib', 'boatHull', 'boatStripe', 'boatFlag'])
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() <= 60
          && request.resource.data.styleToken is string
          && request.resource.data.styleToken.size() <= 24
          && request.resource.data.symbolToken is string
          && request.resource.data.symbolToken.size() <= 24
          && request.resource.data.resolve is string
          && request.resource.data.resolve.size() <= 80
          && ( !('boatSail' in request.resource.data)
            || (request.resource.data.boatSail is string && request.resource.data.boatSail.size() <= 24) )
          && ( !('boatJib' in request.resource.data)
            || (request.resource.data.boatJib is string && request.resource.data.boatJib.size() <= 24) )
          && ( !('boatHull' in request.resource.data)
            || (request.resource.data.boatHull is string && request.resource.data.boatHull.size() <= 24) )
          && ( !('boatStripe' in request.resource.data)
            || (request.resource.data.boatStripe is string && request.resource.data.boatStripe.size() <= 24) )
          && ( !('boatFlag' in request.resource.data)
            || (request.resource.data.boatFlag is string && request.resource.data.boatFlag.size() <= 24) );

        // 退港時に自分のカードを消す。
        allow delete: if request.auth != null && request.auth.uid == memberId;

        // ---- 月ごとの共有記録 ----
        match /months/{monthId} {
          allow read: if isMember();

          allow create, update: if request.auth != null
            && request.auth.uid == memberId
            && isMember()
            && request.resource.data.keys().hasOnly(['days', 'sessions', 'updatedAt'])
            && request.resource.data.days is list
            && request.resource.data.days.size() <= 31
            && request.resource.data.sessions is list
            && request.resource.data.sessions.size() <= 1000;

          allow delete: if request.auth != null && request.auth.uid == memberId;
        }
      }

      // ---- 共同航海(単一ドキュメント voyage/current) ----
      // 目的地を決めると seed から海図(3航路)がひらき、選んだ航路を全員で進む。
      // 航路の中身(海域の位置)は seed からクライアントが決定的に導出するので
      // ここには置かない。進捗もカウンタを持たず、各メンバーの months から
      // 閲覧者が導出する。到着(arrivedAt)は在港者の誰かが1回だけ書ける。
      // 4人の友人港なので、作成・削除は在港者なら誰でも(簡素に)。
      match /voyage/{voyageId} {
        allow read: if isMember();

        // 作成: 在港者が、最小のキー集合で。seed・目標時間(分)・航路番号を検証する。
        allow create: if isMember()
          && request.resource.data.keys().hasOnly(['seed', 'targetMinutes', 'routeIndex', 'createdAt', 'createdBy'])
          && request.resource.data.seed is int
          && request.resource.data.seed >= 0
          && request.resource.data.targetMinutes is int
          && request.resource.data.targetMinutes >= 60
          && request.resource.data.targetMinutes <= 600000
          && request.resource.data.routeIndex is int
          && request.resource.data.routeIndex >= 0
          && request.resource.data.routeIndex <= 2
          && request.resource.data.createdAt is timestamp
          && request.resource.data.createdBy == request.auth.uid;

        // 更新: arrivedAt を一度だけ足せる(到着の刻印)。他フィールドは不変。
        allow update: if isMember()
          && !('arrivedAt' in resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['arrivedAt'])
          && request.resource.data.arrivedAt is timestamp;

        // 削除: 在港者なら誰でも(到着後に「次の航海」で仕舞うため)。
        allow delete: if isMember();
      }

      // ---- 旧「港の試練」(quest/current) ----
      // 共同航海に置き換え済み。デプロイ済みの旧クライアントが読めるよう
      // しばらく残置する(新規の書き込みはもう発生しない)。
      match /quest/{questId} {
        allow read: if isMember();

        // 作成: 在港者が、最小のキー集合で。kind と目標時間(分)を検証する。
        allow create: if isMember()
          && request.resource.data.keys().hasOnly(['kind', 'targetMinutes', 'createdAt', 'createdBy'])
          && request.resource.data.kind in ['kraken', 'storm']
          && request.resource.data.targetMinutes is int
          && request.resource.data.targetMinutes >= 60
          && request.resource.data.targetMinutes <= 600000
          && request.resource.data.createdAt is timestamp
          && request.resource.data.createdBy == request.auth.uid;

        // 更新: defeatedAt を一度だけ足せる(討伐の刻印)。他フィールドは不変。
        allow update: if isMember()
          && !('defeatedAt' in resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['defeatedAt'])
          && request.resource.data.defeatedAt is timestamp;

        // 削除: 在港者なら誰でも(討伐後に「新たな試練」で流すため)。
        allow delete: if isMember();
      }

      // ---- チャット(言葉 + 着岸/帰還の自動の行) ----
      match /chat/{messageId} {
        allow read: if isMember();

        // 発言・自動の行とも、在港者本人だけが自分の uid で書ける。
        allow create: if isMember()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.kind in ['text', 'landfall', 'return']
          && request.resource.data.reactions is map
          && request.resource.data.reactions.size() == 0
          && (
            ( request.resource.data.kind == 'text'
              && request.resource.data.keys().hasOnly(['uid', 'kind', 'text', 'createdAt', 'reactions'])
              && request.resource.data.text is string
              && request.resource.data.text.size() >= 1
              && request.resource.data.text.size() <= 500 )
            ||
            ( request.resource.data.kind in ['landfall', 'return']
              && request.resource.data.keys().hasOnly(['uid', 'kind', 'itemName', 'itemStyle', 'itemSymbol', 'minutes', 'gapDays', 'createdAt', 'reactions'])
              && request.resource.data.itemName is string
              && request.resource.data.itemName.size() <= 60
              && request.resource.data.minutes is int
              && request.resource.data.minutes <= 6000 )
          );

        // 更新はリアクションのみ。自分の枠(reactions[自分のuid])だけを、許可された印で。
        allow update: if isMember()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          && request.resource.data.reactions.diff(resource.data.reactions).affectedKeys().hasOnly([request.auth.uid])
          && ( !(request.auth.uid in request.resource.data.reactions)
            || request.resource.data.reactions[request.auth.uid] in ['lighthouse', 'anchor', 'phoenix'] );

        // 自分の発言だけ、書いてから1時間以内に限り取り下げられる。
        allow delete: if request.auth != null
          && request.auth.uid == resource.data.uid
          && request.time < resource.data.createdAt + duration.value(1, 'h');
      }
    }

    // ---- パブリックの港(公式5港) ----
    // 参加すると、名前・アイコン・作業記録がその港に表示される。
    // 不変条件: 書けるのも消せるのも「書いた本人だけ」。読みはサインイン済みなら誰でも。
    match /publicHarbors/{slug} {
      function validSlug() {
        return slug in ['language', 'certification', 'student', 'reading', 'making'];
      }

      // メンバーのプレイヤーカード。
      match /members/{memberId} {
        allow read: if request.auth != null;

        // boat* は船の見た目(部位id)。任意フィールドなので旧クライアントの書き込みも通る。
        allow create, update: if request.auth != null
          && request.auth.uid == memberId
          && validSlug()
          && request.resource.data.keys().hasOnly(['displayName', 'styleToken', 'symbolToken', 'resolve', 'joinedAt', 'boatSail', 'boatJib', 'boatHull', 'boatStripe', 'boatFlag'])
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() <= 60
          && request.resource.data.styleToken is string
          && request.resource.data.styleToken.size() <= 24
          && request.resource.data.symbolToken is string
          && request.resource.data.symbolToken.size() <= 24
          && request.resource.data.resolve is string
          && request.resource.data.resolve.size() <= 80
          && ( !('boatSail' in request.resource.data)
            || (request.resource.data.boatSail is string && request.resource.data.boatSail.size() <= 24) )
          && ( !('boatJib' in request.resource.data)
            || (request.resource.data.boatJib is string && request.resource.data.boatJib.size() <= 24) )
          && ( !('boatHull' in request.resource.data)
            || (request.resource.data.boatHull is string && request.resource.data.boatHull.size() <= 24) )
          && ( !('boatStripe' in request.resource.data)
            || (request.resource.data.boatStripe is string && request.resource.data.boatStripe.size() <= 24) )
          && ( !('boatFlag' in request.resource.data)
            || (request.resource.data.boatFlag is string && request.resource.data.boatFlag.size() <= 24) );

        // 退港・削除は本人のみ。
        allow delete: if request.auth != null && request.auth.uid == memberId;

        // 月ごとの共有記録。積み上がって残り、消せるのは本人だけ。
        match /months/{monthId} {
          allow read: if request.auth != null;

          allow create, update: if request.auth != null
            && request.auth.uid == memberId
            && validSlug()
            && request.resource.data.keys().hasOnly(['days', 'sessions', 'updatedAt'])
            && request.resource.data.days is list
            && request.resource.data.days.size() <= 31
            && request.resource.data.sessions is list
            && request.resource.data.sessions.size() <= 1000;

          allow delete: if request.auth != null && request.auth.uid == memberId;
        }
      }
    }

    // ---- 通報(書き捨て。読めるのは運営=コンソールのみ) ----
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['reporterUid', 'roomId', 'targetUid', 'messageId', 'text', 'createdAt'])
        && request.resource.data.targetUid is string
        && ( !('text' in request.resource.data) || request.resource.data.text.size() <= 500 );
      allow read, update, delete: if false;
    }
  }
}
